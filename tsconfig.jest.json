{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "isolatedModules": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "outDir": "dist-test",
    "rootDir": "."
  },
  "include": ["./src/**/*", "./test/**/*"],
  "exclude": ["node_modules", "dist", "dist-test"]
}
